<?xml version="1.0"?>
<ruleset name="OA Dues Lookup">
  <description>PHP_CodeSniffer rules for WordPress plugin development.</description>

  <arg name="basepath" value="."/>
  <arg name="colors"/>
  <arg value="p"/>

  <file>oadueslookup.php</file>
  <file>includes</file>
  <file>bin</file>

  <exclude-pattern>*/vendor/*</exclude-pattern>

  <rule ref="WordPress-Core"/>
  <rule ref="WordPress-Extra"/>
  <rule ref="WordPress-Docs"/>
</ruleset>